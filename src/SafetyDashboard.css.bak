/* ── CSS variables ──────────────────────────────────────────────────────── */
:root {
  --urg-critical: #f85149;
  --urg-high:     #f0883e;
  --urg-medium:   #d29624;
  --urg-low:      #3fb950;
}

/* ── Page shell ─────────────────────────────────────────────────────────── */
.sd-page {
  min-height: 100vh;
  background: #0d1117;
  color: #e6edf3;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  padding: 24px 32px 60px;
}

/* ── Header ─────────────────────────────────────────────────────────────── */
.sd-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
  flex-wrap: wrap;
  gap: 12px;
}

.sd-header-left {
  display: flex;
  align-items: center;
  gap: 14px;
}

.sd-shield { font-size: 32px; }

.sd-title {
  margin: 0;
  font-size: 22px;
  font-weight: 700;
}

.sd-subtitle {
  font-size: 11px;
  color: #8b949e;
}

.sd-subtitle code {
  background: #21262d;
  padding: 1px 6px;
  border-radius: 4px;
  color: #58a6ff;
  font-size: 11px;
}

.sd-header-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

/* ── Mode badge + toggle buttons (reuse from NatsMonitor) ───────────────── */
.mode-badge { font-size: 12px; font-weight: 700; padding: 4px 12px; border-radius: 20px; letter-spacing: 0.5px; }
.mode-live   { background: #1a3b1a; color: #3fb950; border: 1px solid #3fb95055; animation: pulse-live 2s infinite; }
.mode-paused { background: #21262d; color: #8b949e; border: 1px solid #30363d; }
@keyframes pulse-live { 0%,100%{box-shadow:0 0 0 0 #3fb95033}50%{box-shadow:0 0 0 6px #3fb95011} }
.btn-toggle  { padding: 8px 18px; border-radius: 8px; border: none; font-size: 13px; font-weight: 600; cursor: pointer; transition: background 0.15s; }
.btn-start   { background: #1f6feb; color: #fff; }
.btn-start:hover { background: #388bfd; }
.btn-stop    { background: #da3633; color: #fff; }
.btn-stop:hover  { background: #f85149; }

/* ── Tabs ───────────────────────────────────────────────────────────────── */
.sd-tabs {
  display: flex;
  gap: 4px;
  margin-bottom: 20px;
  border-bottom: 1px solid #21262d;
  padding-bottom: 0;
}

.sd-tab {
  padding: 9px 18px;
  border: none;
  background: none;
  color: #8b949e;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: color 0.15s, border-color 0.15s;
  border-radius: 6px 6px 0 0;
}

.sd-tab:hover { color: #e6edf3; background: #21262d22; }

.sd-tab-active {
  color: #58a6ff;
  border-bottom-color: #1f6feb;
}

/* ── Stat cards ─────────────────────────────────────────────────────────── */
.sd-stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
  gap: 14px;
  margin-bottom: 20px;
}

.sd-stat-card {
  background: #161b22;
  border: 1px solid #30363d;
  border-radius: 12px;
  padding: 18px 16px 14px;
  text-align: center;
  transition: border-color 0.2s;
}
.sd-stat-card:hover { border-color: #58a6ff44; }

.sd-stat-icon  { font-size: 22px; margin-bottom: 6px; }
.sd-stat-value { font-size: 30px; font-weight: 700; line-height: 1; }
.sd-stat-label { font-size: 11px; color: #8b949e; margin-top: 4px; font-weight: 500; }
.sd-stat-pct   { font-size: 11px; color: #484f58; margin-top: 2px; }

.sd-stat-safe     .sd-stat-value { color: #3fb950; }
.sd-stat-unsafe   .sd-stat-value { color: #f0883e; }
.sd-stat-warning  .sd-stat-value { color: #d29624; }
.sd-stat-critical .sd-stat-value { color: #f85149; }
.sd-stat-viol     .sd-stat-value { color: #f85149; }
.sd-stat-critf    .sd-stat-value { color: #bc8cff; }

/* ── Generic panel ──────────────────────────────────────────────────────── */
.sd-panel {
  background: #161b22;
  border: 1px solid #30363d;
  border-radius: 12px;
  padding: 20px;
}

.sd-panel-title {
  font-size: 13px;
  font-weight: 600;
  color: #8b949e;
  text-transform: uppercase;
  letter-spacing: 0.6px;
  margin-bottom: 16px;
}

/* ── Overview row ───────────────────────────────────────────────────────── */
.sd-overview-row {
  display: grid;
  grid-template-columns: 240px 1fr 1fr;
  gap: 16px;
  margin-bottom: 20px;
}

@media (max-width: 900px) { .sd-overview-row { grid-template-columns: 1fr; } }

/* ── Compliance ring ────────────────────────────────────────────────────── */
.compliance-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.ring-wrap {
  position: relative;
  width: 130px;
  height: 130px;
}

.ring-label {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ring-score { font-size: 30px; font-weight: 700; line-height: 1; }
.ring-sub   { font-size: 11px; color: #8b949e; }

.compliance-legend {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: #8b949e;
}

.cl-dot {
  display: inline-block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

/* ── PPE bars ───────────────────────────────────────────────────────────── */
.ppe-bars { display: flex; flex-direction: column; gap: 14px; }

.ppe-bar-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.ppe-icon  { font-size: 16px; }
.ppe-label { font-size: 12px; color: #e6edf3; min-width: 50px; }

.ppe-track {
  flex: 1;
  height: 10px;
  background: #21262d;
  border-radius: 5px;
  overflow: hidden;
}

.ppe-fill {
  height: 100%;
  border-radius: 5px;
  transition: width 0.6s ease;
}

.ppe-pct { font-size: 12px; font-weight: 600; min-width: 38px; text-align: right; }

/* ── Urgency bars ───────────────────────────────────────────────────────── */
.urg-bars { display: flex; flex-direction: column; gap: 12px; }

.urg-row  { display: flex; align-items: center; gap: 10px; }

.urg-label {
  font-size: 11px;
  font-weight: 700;
  min-width: 72px;
  padding: 2px 8px;
  border-radius: 4px;
  text-align: center;
}

.urg-critical { background: #3d0f0f; color: #f85149; }
.urg-high     { background: #3d1f00; color: #f0883e; }
.urg-medium   { background: #2d2208; color: #d29624; }
.urg-low      { background: #0f2f12; color: #3fb950; }

.urg-track {
  flex: 1;
  height: 8px;
  background: #21262d;
  border-radius: 4px;
  overflow: hidden;
}

.urg-fill {
  height: 100%;
  border-radius: 4px;
  transition: width 0.6s ease;
}

.urg-count { font-size: 12px; color: #8b949e; min-width: 28px; text-align: right; }

/* ── Status breakdown (bar chart) ───────────────────────────────────────── */
.status-breakdown {
  display: flex;
  gap: 24px;
  align-items: flex-end;
  height: 160px;
  padding: 0 20px;
}

.sb-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  flex: 1;
}

.sb-bar-wrap {
  flex: 1;
  width: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.sb-bar {
  width: 60%;
  min-height: 4px;
  border-radius: 4px 4px 0 0;
  transition: height 0.6s ease;
}

.sb-count { font-size: 16px; font-weight: 700; }
.sb-label { font-size: 11px; color: #8b949e; text-transform: uppercase; letter-spacing: 0.4px; }

/* ── Mini table ─────────────────────────────────────────────────────────── */
.sd-mini-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
  cursor: pointer;
}

.sd-mini-table th {
  text-align: left;
  font-size: 11px;
  font-weight: 600;
  color: #8b949e;
  text-transform: uppercase;
  letter-spacing: 0.4px;
  padding: 8px 12px;
  border-bottom: 1px solid #21262d;
}

.sd-mini-table td {
  padding: 8px 12px;
  border-bottom: 1px solid #21262d11;
  vertical-align: middle;
}

.sd-mini-table tr:hover td { background: #21262d; }

/* ── Report list ────────────────────────────────────────────────────────── */
.sd-reports-layout {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 16px;
  align-items: start;
}

@media (max-width: 1100px) { .sd-reports-layout { grid-template-columns: 1fr; } }

.sd-reports-main {
  background: #161b22;
  border: 1px solid #30363d;
  border-radius: 12px;
  overflow: hidden;
}

.sd-filter-bar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6px;
  padding: 14px 16px;
  border-bottom: 1px solid #21262d;
}

.sd-filter-label { font-size: 11px; color: #8b949e; font-weight: 600; }

.filter-btn {
  padding: 3px 10px;
  border-radius: 6px;
  border: 1px solid #30363d;
  background: #21262d;
  color: #8b949e;
  font-size: 11px;
  cursor: pointer;
  transition: all 0.15s;
}

.filter-btn:hover  { border-color: #58a6ff44; color: #e6edf3; }
.filter-active     { background: #1f6feb22; border-color: #1f6feb; color: #58a6ff; }

.sd-filter-count { font-size: 11px; color: #484f58; margin-left: auto; }

.sd-table-scroll { max-height: 520px; overflow-y: auto; }
.sd-table-scroll::-webkit-scrollbar { width: 6px; }
.sd-table-scroll::-webkit-scrollbar-track { background: #161b22; }
.sd-table-scroll::-webkit-scrollbar-thumb { background: #30363d; border-radius: 3px; }

.sd-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
  cursor: pointer;
}

.sd-table thead tr {
  position: sticky;
  top: 0;
  background: #161b22;
  z-index: 1;
}

.sd-table th {
  padding: 10px 14px;
  text-align: left;
  font-size: 11px;
  font-weight: 600;
  color: #8b949e;
  text-transform: uppercase;
  letter-spacing: 0.4px;
  border-bottom: 1px solid #21262d;
}

.sd-row td {
  padding: 9px 14px;
  border-bottom: 1px solid #21262d11;
  vertical-align: middle;
}

.sd-row:hover td         { background: #21262d; }
.sd-row-selected td      { background: #1f6feb18; }
.sd-row-new td           { animation: flash-row 2s ease-out; }

@keyframes flash-row { 0% { background: #3fb95022; } 100% { background: transparent; } }

/* ── Badges ─────────────────────────────────────────────────────────────── */
.sd-status-badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.3px;
}

.safe     { background: #0f2f12; color: #3fb950; border: 1px solid #3fb95044; }
.unsafe   { background: #3d1f00; color: #f0883e; border: 1px solid #f0883e44; }
.warning  { background: #2d2208; color: #d29624; border: 1px solid #d2962444; }
.critical { background: #3d0f0f; color: #f85149; border: 1px solid #f8514944; }

.sd-urg-badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 700;
}

.urg-critical { background: #3d0f0f; color: #f85149; }
.urg-high     { background: #3d1f00; color: #f0883e; }
.urg-medium   { background: #2d2208; color: #d29624; }
.urg-low      { background: #0f2f12; color: #3fb950; }

.sd-source-chip {
  background: #21262d;
  border: 1px solid #30363d;
  border-radius: 6px;
  padding: 2px 8px;
  font-size: 11px;
  color: #58a6ff;
  font-family: monospace;
}

/* ── PPE mini icons ─────────────────────────────────────────────────────── */
.ppe-mini      { display: flex; gap: 4px; }
.ppe-ok        { opacity: 1; font-size: 14px; }
.ppe-miss      { opacity: 0.2; font-size: 14px; }

/* ── Score pill ─────────────────────────────────────────────────────────── */
.score-pill-wrap { display: flex; }
.score-pill {
  font-size: 12px;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 6px;
}

.sd-td-viols { text-align: center; font-weight: 700; color: #f85149; }
.sd-td-time  { color: #8b949e; font-family: monospace; font-size: 12px; white-space: nowrap; }
.sd-report-id { font-size: 11px; color: #58a6ff; }

/* ── Detail panel ───────────────────────────────────────────────────────── */
.detail-panel {
  background: #161b22;
  border: 1px solid #30363d;
  border-radius: 12px;
  padding: 20px;
  max-height: 580px;
  overflow-y: auto;
  position: sticky;
  top: 80px;
}

.detail-panel::-webkit-scrollbar { width: 5px; }
.detail-panel::-webkit-scrollbar-thumb { background: #30363d; border-radius: 3px; }

.detail-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16px;
}

.detail-title { font-size: 12px; color: #8b949e; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
.detail-id    { font-size: 13px; color: #58a6ff; }

.detail-close {
  background: #21262d;
  border: 1px solid #30363d;
  border-radius: 6px;
  color: #8b949e;
  font-size: 13px;
  width: 28px;
  height: 28px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.detail-close:hover { background: #f8514922; color: #f85149; border-color: #f85149; }

.detail-meta        { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; background: #0d1117; border-radius: 8px; padding: 12px; }
.dm-row             { display: flex; align-items: center; gap: 10px; }
.dm-key             { font-size: 11px; color: #8b949e; min-width: 100px; flex-shrink: 0; }
.dm-val             { font-size: 12px; color: #e6edf3; }

.detail-section-title {
  font-size: 11px;
  font-weight: 600;
  color: #8b949e;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin: 14px 0 8px;
}

.critical-title { color: #f85149; }

.detail-ppe-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 8px;
}

.detail-ppe-tile {
  border-radius: 8px;
  padding: 10px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  border: 1px solid transparent;
}

.tile-ok   { background: #0f2f12; border-color: #3fb95033; }
.tile-fail { background: #3d0f0f; border-color: #f8514933; }

.tile-icon   { font-size: 20px; }
.tile-name   { font-size: 11px; color: #8b949e; }
.tile-status { font-size: 11px; font-weight: 700; }
.tile-ok .tile-status   { color: #3fb950; }
.tile-fail .tile-status { color: #f85149; }

.detail-allppe {
  text-align: center;
  padding: 8px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 700;
  margin-bottom: 4px;
}
.allppe-ok   { background: #0f2f12; color: #3fb950; }
.allppe-fail { background: #3d0f0f; color: #f85149; }

.detail-score-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 4px;
}

.detail-score-bar-wrap {
  flex: 1;
  height: 10px;
  background: #21262d;
  border-radius: 5px;
  overflow: hidden;
}

.detail-score-bar { height: 100%; border-radius: 5px; transition: width 0.5s ease; }
.detail-score-num { font-size: 13px; font-weight: 700; min-width: 50px; text-align: right; color: #e6edf3; }

.detail-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.detail-list li {
  font-size: 12px;
  padding: 6px 10px;
  border-radius: 6px;
  line-height: 1.4;
}

.detail-list-warn     li { background: #2d220833; color: #d29624; border: 1px solid #d2962422; }
.detail-list-critical li { background: #3d0f0f33; color: #f85149; border: 1px solid #f8514922; }
.detail-list-rec      li { background: #0b204433; color: #58a6ff; border: 1px solid #58a6ff22; }
.detail-list-action   li { background: #21262d;   color: #e6edf3; border: 1px solid #30363d; }

/* ── Violations tab ─────────────────────────────────────────────────────── */
.sd-viols-layout { display: flex; flex-direction: column; gap: 16px; }

.viol-type-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 10px;
}

.viol-type-card {
  background: #0d1117;
  border: 1px solid #21262d;
  border-radius: 8px;
  padding: 12px 14px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.vtc-icon  { font-size: 18px; }
.vtc-name  { flex: 1; font-size: 12px; color: #e6edf3; }
.vtc-count {
  background: #f8514922;
  color: #f85149;
  font-size: 13px;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 6px;
}

.viol-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px; }

.viol-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 12px;
  background: #0d1117;
  border: 1px solid #21262d;
  border-radius: 6px;
}

.viol-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.viol-dot-safe     { background: #3fb950; }
.viol-dot-unsafe   { background: #f0883e; }
.viol-dot-warning  { background: #d29624; }
.viol-dot-critical { background: #f85149; }

.viol-text   { flex: 1; font-size: 12px; color: #e6edf3; }
.viol-report { font-size: 11px; color: #484f58; }

/* ── Actions tab ────────────────────────────────────────────────────────── */
.actions-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 12px;
}

.action-card {
  background: #0d1117;
  border: 1px solid #21262d;
  border-radius: 8px;
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.action-text   { font-size: 13px; color: #e6edf3; line-height: 1.4; }
.action-meta   { display: flex; align-items: center; justify-content: space-between; }
.action-report { font-size: 11px; color: #58a6ff; }
.action-time   { font-size: 11px; color: #484f58; }

.rec-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }

.rec-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 14px;
  background: #0d1117;
  border: 1px solid #21262d;
  border-radius: 6px;
}

.rec-icon   { font-size: 16px; flex-shrink: 0; margin-top: 1px; }
.rec-text   { flex: 1; font-size: 12px; color: #e6edf3; line-height: 1.4; }
.rec-report { font-size: 11px; color: #484f58; white-space: nowrap; }

/* Back to home - green */
.back-home-btn { border-color: #3fb95044; color: #3fb950; }
.back-home-btn:hover { border-color: #3fb950; background: #3fb95018; color: #56d364; }

/* ── Animated Alert Character ────────────────────────────────────────────── */
.alert-character-overlay {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 9999;
  animation: alert-slide-in 0.5s ease-out;
}

@keyframes alert-slide-in {
  from { transform: translateX(120%); opacity: 0; }
  to   { transform: translateX(0); opacity: 1; }
}

.alert-character {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}

/* ── Humanoid figure ──────────────────────────────────────────────────── */
.alert-humanoid {
  position: relative;
  width: 80px;
  height: 120px;
  animation: alert-bounce 1s ease-in-out infinite;
}

@keyframes alert-bounce {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-10px); }
}

/* Head */
.humanoid-head {
  width: 36px;
  height: 36px;
  background: linear-gradient(135deg, #58a6ff, #1f6feb);
  border-radius: 50%;
  margin: 0 auto 4px;
  position: relative;
  box-shadow: 0 0 14px #58a6ff66;
  animation: head-tilt 2s ease-in-out infinite alternate;
}

@keyframes head-tilt {
  0%   { transform: rotate(-6deg); }
  100% { transform: rotate(6deg); }
}

.humanoid-eye {
  position: absolute;
  width: 6px;
  height: 8px;
  background: #fff;
  border-radius: 50%;
  top: 12px;
  animation: eye-blink 3s ease-in-out infinite;
}

.humanoid-eye.left  { left: 9px; }
.humanoid-eye.right { right: 9px; }

@keyframes eye-blink {
  0%, 42%, 46%, 100% { transform: scaleY(1); }
  44%                { transform: scaleY(0.1); }
}

.humanoid-mouth {
  position: absolute;
  width: 10px;
  height: 5px;
  border-bottom: 2px solid #fff;
  border-radius: 0 0 50% 50%;
  bottom: 7px;
  left: 50%;
  transform: translateX(-50%);
  animation: mouth-talk 0.4s ease-in-out infinite alternate;
}

@keyframes mouth-talk {
  0%   { height: 3px; width: 8px; }
  100% { height: 6px; width: 12px; }
}

/* Torso */
.humanoid-torso {
  width: 28px;
  height: 30px;
  background: linear-gradient(180deg, #f85149, #da3633);
  border-radius: 6px 6px 4px 4px;
  margin: 0 auto;
  position: relative;
  box-shadow: 0 0 10px #f8514944;
}

/* Arms */
.humanoid-arm {
  position: absolute;
  width: 8px;
  height: 28px;
  background: linear-gradient(180deg, #f85149, #da3633);
  border-radius: 4px;
  top: 2px;
}

.humanoid-arm.left-arm {
  left: -12px;
  transform-origin: top center;
  animation: wave-left 0.6s ease-in-out infinite alternate;
}

.humanoid-arm.right-arm {
  right: -12px;
  transform-origin: top center;
  animation: wave-right 0.8s ease-in-out infinite alternate;
}

@keyframes wave-left {
  0%   { transform: rotate(10deg); }
  100% { transform: rotate(-30deg); }
}

@keyframes wave-right {
  0%   { transform: rotate(-10deg); }
  100% { transform: rotate(40deg); }
}

/* Legs */
.humanoid-legs {
  display: flex;
  justify-content: center;
  gap: 4px;
  margin-top: 2px;
}

.humanoid-leg {
  width: 10px;
  height: 22px;
  background: #21262d;
  border-radius: 4px 4px 6px 6px;
}

.humanoid-leg.left-leg {
  animation: leg-step 0.8s ease-in-out infinite alternate;
}

.humanoid-leg.right-leg {
  animation: leg-step 0.8s ease-in-out 0.4s infinite alternate;
}

@keyframes leg-step {
  0%   { transform: translateY(0); }
  100% { transform: translateY(-3px); }
}

/* Pulse ring behind humanoid */
.alert-humanoid .alert-character-wave {
  position: absolute;
  top: -10px;
  left: -10px;
  right: -10px;
  bottom: -10px;
  border-radius: 50%;
  border: 2px solid #f8514966;
  animation: alert-pulse-ring 1.5s ease-out infinite;
}

@keyframes alert-pulse-ring {
  0%   { transform: scale(1); opacity: 1; }
  100% { transform: scale(1.6); opacity: 0; }
}

/* Speech bubble */
.alert-character-bubble {
  background: #2d1010;
  border: 1px solid #f85149;
  border-radius: 12px;
  padding: 10px 16px;
  color: #f85149;
  font-size: 13px;
  font-weight: 500;
  max-width: 240px;
  text-align: center;
  box-shadow: 0 4px 20px #f8514933;
  animation: alert-bubble-pulse 2s ease-in-out infinite;
}

@keyframes alert-bubble-pulse {
  0%, 100% { box-shadow: 0 4px 20px #f8514933; }
  50%      { box-shadow: 0 4px 30px #f8514966; }
}

.alert-character-bubble strong {
  color: #ff7b72;
  font-size: 16px;
}
